<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE glassfish-web-app PUBLIC "-//GlassFish.org//DTD GlassFish Application Server 3.1 Servlet 3.0//EN" "http://glassfish.org/dtds/glassfish-web-app_3_0-1.dtd">
<glassfish-web-app error-url="">
  <!--
        Force the context root to /glimpse-rest so the URL is always:
            http://localhost:8080/glimpse-rest/resources/videos/...
        regardless of the Maven artifact version (glimpse-rest-1.0, etc.)
    -->
  <context-root>/glimpse-rest</context-root>
  <class-loader delegate="true"/>
</glassfish-web-app>
